# === Telegram Configuration ===
# Token del bot (lo obtenés de @BotFather en Telegram)
TELEGRAM_BOT_TOKEN=tu_token_aqui

# Tu chat ID (ver docs/setup-guide.md para cómo obtenerlo)
TELEGRAM_CHAT_ID=tu_chat_id_aqui

# === Modo de ejecución ===
# Poner en "true" para probar sin enviar mensajes a Telegram
DRY_RUN=true

# === Travelpayouts / Aviasales Data API (2ª fuente, opcional) ===
# Token gratuito: travelpayouts.com → Profile → API token.
# Sin token, la fuente se saltea con un log (no rompe nada).
TRAVELPAYOUTS_TOKEN=tu_token_aqui
# Opcional: forzar el market del cache (ej: "br", "us"). Default: lo infiere del origen.
# TRAVELPAYOUTS_MARKET=
